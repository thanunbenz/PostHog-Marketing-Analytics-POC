# --- PostHog (POC) ---------------------------------------------------------
# Leave BLANK to run in DEMO MODE: events are logged live in the UI / server
# console but NOT sent to PostHog. Fill these in to send real events.
#
# Get keys from PostHog -> Project Settings -> Project API Key.
# Free tier = 1M events/mo (per PRD §9).

# Client key (browser, "phc_..."). Safe to expose — this is a write-only key.
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog host. EU cloud: https://eu.i.posthog.com  | US cloud: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Server key for the webhook (server-side subscription_started).
# In production this is the authoritative, anti-adblock path (PRD §6.4).
# Can reuse the same project key above; kept separate to mirror prod env wiring.
POSTHOG_SERVER_KEY=
POSTHOG_SERVER_HOST=https://eu.i.posthog.com
